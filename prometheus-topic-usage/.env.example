# Confluent telemetry credentials (Cloud API key/secret)
CLOUD_API_KEY=MOCK
CLOUD_API_SECRET=MOCK

# Kafka cluster id to scrape in Prometheus
CFLT_CLUSTER_ID=lkc-xzy

# Prometheus runtime tuning
PROM_RETENTION_TIME=180d
PROM_SCRAPE_INTERVAL=1m
PROM_SCRAPE_TIMEOUT=55s

# Kafka REST credentials for topic inventory in report script
KAFKA_API_ENDPOINT=https://pkc-xxxxx.region.provider.confluent.cloud
KAFKA_API_KEY=
KAFKA_API_SECRET=
